{
  "manifest_version": 3,
  "name": "Antri Job Saver",
  "version": "0.3.0",
  "description": "Capture the current job page and open an Antri application draft.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://antri.xyz/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://antri.xyz/*"],
      "js": ["session-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Save job to Antri",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
